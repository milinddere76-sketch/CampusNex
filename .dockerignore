# ============================================================================
# CAMPUSNEX GLOBAL DOCKERIGNORE (PRODUCTION BUILD OPTIMIZATION)
# ============================================================================

# Exclude all node_modules recursively to prevent overwriting clean builds
**/node_modules/
node_modules/

# Exclude local environment files and credentials
.env*
.git/
.gitignore

# Exclude the Flutter mobile application codebase and its build artifacts
app/
.dart_tool/
build/

# Exclude large development/orchestration utilities
docker-compose.yml
npm-debug.log*
yarn-debug.log*

# Exclude operating system and editor configuration files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
