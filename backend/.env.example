# ============================================================================
# CAMPUSNEX ENVIRONMENT VARIABLES — COPY THIS FILE TO .env AND FILL IN VALUES
# ============================================================================

# Server
NODE_ENV=production
PORT=8080

# JWT — REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_64_CHAR_SECRET
JWT_EXPIRE=7d

# PostgreSQL (set automatically by Fly.io when you run `fly postgres attach`)
DATABASE_URL=postgres://user:password@host:5432/campusnex

# OR set individual fields (used when DATABASE_URL is not set)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=campusnex

# CORS — set to your production frontend URL
FRONTEND_URL=https://campusnex.fly.dev

# Optional: Stripe payment gateway integration
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
